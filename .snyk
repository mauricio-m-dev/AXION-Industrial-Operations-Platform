version: v1.25.0
ignore:
  SNYK-JS-INFLIGHT-6095116:
    - "*":
        reason: "No fix available, low impact"
        expires: "2027-01-01T00:00:00.000Z"
  javascript/HTTPSourceWithUncheckedType:
    - "*":
        reason: "Type coercion explicitly handles edge cases"
        expires: "2027-01-01T00:00:00.000Z"
